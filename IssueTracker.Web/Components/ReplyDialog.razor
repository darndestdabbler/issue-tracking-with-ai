@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@isFormValid">
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudSelect T="int"
                               Label="From"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="From is required"
                               Value="reply.FromActorId"
                               ValueChanged="OnFromActorChanged">
                        @foreach (var actor in Actors)
                        {
                            <MudSelectItem Value="@actor.Id">@actor.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6">
                    <MudSelect @bind-Value="reply.ActionType"
                               Label="Action"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="Action Type is required">
                        @foreach (var action in AvailableActions)
                        {
                            <MudSelectItem Value="@action.Value">@action.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudSelect @bind-Value="reply.SessionId"
                               Label="Session"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="Session is required">
                        @foreach (var session in Sessions)
                        {
                            <MudSelectItem Value="@session.Id">@session.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="reply.Text"
                                  Label="Reply"
                                  Variant="Variant.Outlined"
                                  FullWidth="true"
                                  Lines="4"
                                  Required="true"
                                  RequiredError="Reply text is required"
                                  Placeholder="Add your comment, decision, or status update" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect @bind-Value="reply.ToActorId"
                               Label="Assign to (optional)"
                               Variant="Variant.Outlined"
                               Clearable="true">
                        @foreach (var actor in Actors)
                        {
                            <MudSelectItem Value="@((int?)actor.Id)">@actor.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit"
                   Disabled="@(!isFormValid)">
            Submit Reply
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialogInstance { get; set; } = null!;

    [Parameter] public List<SessionDto> Sessions { get; set; } = new();
    [Parameter] public List<ActorDto> Actors { get; set; } = new();
    [Parameter] public int RootPostId { get; set; }
    [Parameter] public int? FilterSessionId { get; set; }
    [Parameter] public string RootPostStatus { get; set; } = "Open";
    [Parameter] public int RootPostFromActorId { get; set; }
    [Parameter] public int? RootPostToActorId { get; set; }

    private ReplyRequest reply = new();
    private MudForm? form;
    private bool isFormValid = true;

    private record ActionOption(string Value, string Label);

    private List<ActionOption> AvailableActions => GetAvailableActions();

    private bool CanArchive
    {
        get
        {
            var actor = Actors.FirstOrDefault(a => a.Id == reply.FromActorId);
            return actor?.Role == "Admin"
                || reply.FromActorId == RootPostFromActorId
                || reply.FromActorId == RootPostToActorId;
        }
    }

    private bool ResolvesAsArchive => CanArchive;

    protected override void OnInitialized()
    {
        reply.ActionForId = RootPostId;
        reply.FromActorId = 2; // Default to Human for UI replies

        if (FilterSessionId.HasValue)
            reply.SessionId = FilterSessionId.Value;
        else if (Sessions.Any())
            reply.SessionId = Sessions.Last().Id; // Most recent session
    }

    private void OnFromActorChanged(int newFromActorId)
    {
        reply.FromActorId = newFromActorId;

        // If the selected action is no longer available, reset to Discuss
        if (AvailableActions.All(a => a.Value != reply.ActionType))
            reply.ActionType = "Discuss";
    }

    private List<ActionOption> GetAvailableActions()
    {
        var actions = new List<ActionOption>
        {
            new("Discuss", "Discuss"),
            new("Proceed As Is", "Proceed As Is"),
            new("Proceed With Mods", "Proceed With Mods"),
            new("Check", "Check (Request Review)")
        };

        // Hold: only when issue is Open
        if (RootPostStatus == "Open")
            actions.Add(new("Hold", "Hold (Defer Issue)"));

        // Resolve: available when Open or Deferred
        if (RootPostStatus is "Open" or "Deferred")
        {
            var label = ResolvesAsArchive ? "Resolve (Archive)" : "Resolve (Pending Review)";
            actions.Add(new("Resolve", label));
        }

        // Archive: only if actor has permission, and issue isn't already Closed
        if (CanArchive && RootPostStatus != "Closed")
            actions.Add(new("Archive", "Archive (Close Issue)"));

        // Reopen: only when Closed, Deferred, or Pending Review
        if (RootPostStatus is "Closed" or "Deferred" or "Pending Review")
            actions.Add(new("Reopen", "Reopen (Open Issue)"));

        return actions;
    }

    private async Task Submit()
    {
        if (form != null)
        {
            await form.Validate();
            if (form.IsValid)
            {
                MudDialogInstance.Close(DialogResult.Ok(reply));
            }
        }
    }

    private void Cancel()
    {
        MudDialogInstance.Cancel();
    }
}
