@using MudBlazor

<MudDialog>
    <DialogContent>
        <div style="max-height: 70vh; overflow-y: auto; padding: 8px;">
            <MarkdownRenderer Content="@Content" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialogInstance { get; set; } = null!;

    /// <summary>The Markdown content to display in the viewer.</summary>
    [Parameter] public string Content { get; set; } = "";

    private void Close() => MudDialogInstance.Cancel();
}
